# 環境
ENV=development
PORT=3000
APP_NAME=預設專案
BASE_URL=

# JWT
JWT_SECRET=your_jwt_secret_here

# 資料庫（MariaDB / MySQL）
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_db_password
DB_DATABASE=your_db_name

# 信箱（Nodemailer，如不使用可移除）
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your@email.com
MAIL_PASS=your_mail_password
